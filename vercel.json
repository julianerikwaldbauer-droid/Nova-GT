{
  "rewrites": [
    {
      "source": "/",
      "destination": "/NOVA-GT-finished-product/nova-gt-concept-website/index.html"
    },
    {
      "source": "/assets/:path*",
      "destination": "/NOVA-GT-finished-product/nova-gt-concept-website/assets/:path*"
    },
    {
      "source": "/styles.css",
      "destination": "/NOVA-GT-finished-product/nova-gt-concept-website/styles.css"
    },
    {
      "source": "/script.js",
      "destination": "/NOVA-GT-finished-product/nova-gt-concept-website/script.js"
    },
    {
      "source": "/favicon.svg",
      "destination": "/NOVA-GT-finished-product/nova-gt-concept-website/assets/favicon.svg"
    }
  ]
}
